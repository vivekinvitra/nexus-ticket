# ── Site Configuration ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.ticket-nexus.com
NEXT_PUBLIC_SITE_NAME=Tickets nexus

# ── Database (optional — uses static datastore by default) ──
DATABASE_URL=
DB_SERVER=localhost
DB_DATABASE=Ticketsnexus
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_ENCRYPT=true

# ── Redis Cache (optional) ────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Affiliate Partner API Keys ────────────────────────
TICKETMASTER_API_KEY=
TICKETMASTER_SECRET=

STUBHUB_CLIENT_ID=
STUBHUB_CLIENT_SECRET=

VIAGOGO_CLIENT_ID=
VIAGOGO_CLIENT_SECRET=

# ── Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Environment ───────────────────────────────────────
NODE_ENV=development
