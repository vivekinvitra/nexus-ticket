{
  "version": 3,
  "middleware": {},
  "functions": {
    "/news/page": {
      "files": [
        "server/server-reference-manifest.js",
        "server/app/news/page_client-reference-manifest.js",
        "server/middleware-build-manifest.js",
        "server/middleware-react-loadable-manifest.js",
        "server/next-font-manifest.js",
