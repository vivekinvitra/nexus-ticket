      ],
      "name": "app/news/page",
      "page": "/news/page",
      "matchers": [
        {
          "regexp": "^/news$",
          "originalSource": "/news"
        }
      ],
      "wasm": [],
      "assets": [],
      "environments": {}
    },
    "/page": {
      "files": [
        "server/server-reference-manifest.js",
        "server/app/page_client-reference-manifest.js",
        "server/middleware-build-manifest.js",
